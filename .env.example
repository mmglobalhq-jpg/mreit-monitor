# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=filings

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...
EXTRACTION_MODEL=claude-sonnet-4-20250514
COMPARISON_MODEL=claude-opus-4-20250514
MAX_EXTRACTION_RETRIES=3

# Resend Email
RESEND_API_KEY=re_...
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=mREIT Monitor <alerts@yourdomain.com>

# SEC EDGAR (must include real contact email per SEC policy)
EDGAR_USER_AGENT=mREIT-Monitor you@example.com

# Summary Reports
SUMMARY_MODEL=claude-opus-4-20250514
SUMMARY_ENABLED=false

# Frontend API
REIT_MONITOR_API_KEY=your-secret-api-key-here
CORS_ORIGINS=https://mmglob.com,http://localhost:3000

# Webhook (optional — fires when summary reports are generated)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Scheduler
POLL_HOUR=6
POLL_MINUTE=0
POLL_TIMEZONE=US/Eastern

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
