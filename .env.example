# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=reit-filings

# OpenRouter (all LLM calls go through OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model selection (OpenRouter model IDs)
EXTRACTION_MODEL=anthropic/claude-haiku-4.5
COMPARISON_MODEL=anthropic/claude-sonnet-4.6
SUMMARY_MODEL=anthropic/claude-sonnet-4.6
MAX_EXTRACTION_RETRIES=3

# Ollama (optional — free local fallback for IR page scraping)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_SCRAPER_MODEL=qwen3:4b
# LOCAL_EXTRACTION=false

# Resend Email (optional — alerts on new extractions)
RESEND_API_KEY=re_...
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=mREIT Monitor <alerts@yourdomain.com>

# SEC EDGAR — required: must include your real contact email per SEC fair-access policy
EDGAR_USER_AGENT=mREIT-Monitor you@example.com

# Scheduler
POLL_HOUR=7
POLL_MINUTE=0
POLL_TIMEZONE=US/Eastern

# Summary Reports
SUMMARY_ENABLED=true
# WEBHOOK_URL=https://your-app.com/webhooks/reit-report
# WEBHOOK_SECRET=

# API Authentication
REIT_MONITOR_API_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Usage metering (optional — POST /usage/record to a gateway service; no-op if blank)
# GATEWAY_URL=http://localhost:8001

# App
LOG_LEVEL=INFO
ENVIRONMENT=production
APP_HOST=127.0.0.1
APP_PORT=8012
